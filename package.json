{
  "name": "sakura-mahar",
  "version": "1.0.0",
  "description": "Sakura Mahar - Beautiful React Web Application",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "woy": "^0.0.1"
  },
  "scripts": {
    "postinstall": "npm --prefix backend install",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "firebase:serve": "node scripts/firebase-cli.js emulators:start --only functions,firestore,storage,hosting",
    "firebase:deploy": "node scripts/firebase-cli.js deploy",
    "firebase:seed": "npm --prefix backend run seed:firebase"
  },
  "proxy": "http://localhost:5000",
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "firebase-tools": "^15.14.0",
    "vercel": "^51.6.1"
  }
}
