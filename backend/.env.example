# SAKURA MAHAR - ENVIRONMENT VARIABLES TEMPLATE

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
# Change this to a strong secret in production!
JWT_SECRET=sakura_mahar_super_secret_key_change_this_in_production

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/sakura-mahar

# API URLs
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional - for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Payment Gateway (Optional - for future use)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Cloudinary Remote Storage (Optional)
# Set these values to enable Cloudinary uploads for media assets.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# File Upload (Optional)
# MAX_FILE_SIZE=10485760
# UPLOAD_DIR=uploads/
